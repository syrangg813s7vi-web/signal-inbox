APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signal_inbox
REDIS_URL=redis://localhost:6379
KNOWLEDGE_ENRICHMENT_API_KEY=
# Leave unset to use the code default. GLM-compatible `glm-*` models and
# `*.bigmodel.cn` endpoints default to 60000 ms; other OpenAI-compatible
# endpoints default to 15000 ms. A legacy configured value of 15000 is also
# promoted to 60000 for GLM-compatible runtimes.
KNOWLEDGE_ENRICHMENT_TIMEOUT_MS=
KNOWLEDGE_ENRICHMENT_PROVIDER=openai
KNOWLEDGE_ENRICHMENT_MODEL=gpt-4o-mini-2024-07-18
KNOWLEDGE_ENRICHMENT_BASE_URL=
