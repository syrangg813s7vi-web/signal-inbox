{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@signal-inbox/ai": ["packages/ai/src"],
      "@signal-inbox/capture": ["packages/capture/src"],
      "@signal-inbox/connectors": ["packages/connectors/src"],
      "@signal-inbox/core": ["packages/core/src"],
      "@signal-inbox/db": ["packages/db/src"],
      "@signal-inbox/delivery": ["packages/delivery/src"],
      "@signal-inbox/knowledge": ["packages/knowledge/src"],
      "@signal-inbox/normalization": ["packages/normalization/src"],
      "@signal-inbox/processors": ["packages/processors/src"],
      "@signal-inbox/review": ["packages/review/src"]
    }
  }
}
