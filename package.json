{
  "name": "signal-inbox",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:services": "docker compose up -d",
    "dev:services:stop": "docker compose down",
    "dev": "node scripts/run-web-command.mjs dev",
    "build": "node scripts/run-web-command.mjs build",
    "start": "node scripts/run-web-command.mjs start",
    "typecheck": "pnpm -r typecheck",
    "validate": "pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
